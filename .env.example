# ============================================
# WEBAPP TEMPLATE - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================

# ============================================
# SUPABASE (create project at supabase.com)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# For local development (supabase start):
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase start output>
# SUPABASE_SERVICE_ROLE_KEY=<from supabase start output>

# ============================================
# EMAIL (Resend - resend.com)
# ============================================
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# AI PROVIDERS
# ============================================
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxx
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# Alternative: OpenAI
# OPENAI_API_KEY=sk-xxxx

# Alternative: Groq (free tier, fast)
# AI_PROVIDER=groq
# AI_API_KEY=gsk_xxxx
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# Alternative: Ollama (local, free)
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen2.5:14b

# Research APIs
# TAVILY_API_KEY=your_tavily_api_key

# ============================================
# PAYMENTS (Stripe - stripe.com)
# ============================================
# STRIPE_SECRET_KEY=sk_test_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# ANALYTICS (optional)
# ============================================
# GOOGLE_ANALYTICS_PROPERTY_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxx

# ============================================
# AUTOMATION (optional)
# ============================================
# N8N_INTEGRATION_TOKEN=your_n8n_webhook_token

# ============================================
# CRON JOBS (Vercel Cron, optional)
# ============================================
# CRON_SECRET=your-cron-secret-here

# ============================================
# RATE LIMITING (optional, for production scale)
# ============================================
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# ============================================
# BRANDING (change to white-label the platform)
# ============================================
NEXT_PUBLIC_BRAND_NAME=Real Tech LLC
NEXT_PUBLIC_BRAND_SHORT=Real Tech
NEXT_PUBLIC_BRAND_INITIALS=RT
NEXT_PUBLIC_BRAND_URL=https://realtechconsultant.com
NEXT_PUBLIC_BRAND_TAGLINE=Your Tagline
NEXT_PUBLIC_POWERED_BY=Powered by Real Tech LLC
